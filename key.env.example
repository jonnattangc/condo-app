# Plantilla de credenciales para el build firmado en Docker.
# Copiar a "key.env" y rellenar con valores reales. NO versionar key.env.
#
#   cp key.env.example key.env
#
# Credenciales del keystore de release:
KEYSTORE_PASSWORD=tu_password_del_keystore
KEY_ALIAS=tu_alias
KEY_PASSWORD=tu_password_de_la_clave

# API keys opcionales (si no se definen, los mapas usaran "__NO_FOUND__"):
API_KEY_GOOGLE_MAPS=
MAP_BOX_KEY=
